<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_discount_approval_wizard_form" model="ir.ui.view">
        <field name="name">purchase.discount.approval.wizard.form</field>
        <field name="model">purchase.discount.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Purchase Order Discount Approval">
                <sheet>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label for="partner_id" class="fw-bold text-muted">Vendor</label>
                            <field name="partner_id" readonly="1" nolabel="1"/>
                        </div>
                        <div class="col-6">
                            <label for="amount_total" class="fw-bold text-muted">PO Total</label>
                            <field name="amount_total" readonly="1" nolabel="1"/>
                        </div>
                    </div>
                    <div class="alert alert-warning mb-3" role="alert">
                        <h5 class="alert-heading">📊 Discount Summary</h5>
                        <div class="row">
                            <div class="col-6">
                                <strong>Max Line Discount:</strong>
                                <field name="current_discount_percent" readonly="1" nolabel="1"
                                       widget="percentage" class="ms-1 text-danger fw-bold"/>
                            </div>
                            <div class="col-6">
                                <strong>Total Discount Amount:</strong>
                                <field name="current_discount_amount" readonly="1" nolabel="1"
                                       class="ms-1 text-danger fw-bold"/>
                            </div>
                        </div>
                    </div>
                    <group>
                        <field name="action" widget="radio" options="{'horizontal': true}"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="order_id" invisible="1"/>
                    </group>
                    <group string="Approval Details" invisible="action != 'approve'">
                        <field name="approval_notes" placeholder="Optional notes..."/>
                        <field name="use_counter_offer"/>
                        <group invisible="not use_counter_offer">
                            <field name="counter_offer_percent"/>
                            <field name="counter_offer_amount"/>
                            <div class="alert alert-info col-12">
                                <i class="fa fa-info-circle me-1"/>
                                Lines with discount exceeding the approved max will be automatically reduced.
                            </div>
                        </group>
                    </group>
                    <group string="Rejection Details" invisible="action != 'reject'">
                        <field name="rejected_reason"
                               placeholder="Please provide a clear reason for rejection... (Required)"
                               required="action == 'reject'"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="✅ Approve" type="object"
                            class="btn-success" invisible="action != 'approve'" data-hotkey="v"/>
                    <button name="action_confirm" string="❌ Reject" type="object"
                            class="btn-danger" invisible="action != 'reject'" data-hotkey="v"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
