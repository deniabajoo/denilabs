<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_bt_bridge" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.dl_bt_bridge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Insert Mobile BT Print setting BEFORE ePos Printer in Connected Devices -->
            <xpath expr="//block[@id='pos_connected_devices_section']/setting[@id='pos_other_devices']"
                   position="before">
                <setting id="pos_bt_print"
                         string="Mobile Bluetooth Print"
                         help="Print receipts directly to a Bluetooth thermal printer from Android devices">
                    <field name="pos_bt_print_enabled"/>
                    <div class="content-group mt16" invisible="not pos_bt_print_enabled">
                        <div class="row">
                            <label string="Intent Scheme"
                                   for="pos_bt_intent_scheme"
                                   class="col-lg-4 o_light_label"/>
                            <field name="pos_bt_intent_scheme"/>
                        </div>
                        <div class="row mt8">
                            <label string="Paper Size"
                                   for="pos_bt_paper_size"
                                   class="col-lg-4 o_light_label"/>
                            <field name="pos_bt_paper_size"/>
                        </div>
                        <div class="mt8 text-muted">
                            <i class="fa fa-info-circle me-1"/>
                            Requires <b>RawBT</b> (or the selected app) installed on the
                            Android device with a Bluetooth printer paired.
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
