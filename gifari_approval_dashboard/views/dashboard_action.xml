<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client Action for OWL Dashboard -->
    <record id="action_gifari_approval_dashboard" model="ir.actions.client">
        <field name="name">Approval Dashboard</field>
        <field name="tag">gifari_approval_dashboard</field>
    </record>

    <!-- Shortcut under Sales menu -->
    <menuitem
        id="menu_sale_approval_dashboard"
        name="📊 Approval Dashboard"
        parent="sale.sale_menu_root"
        action="action_gifari_approval_dashboard"
        sequence="16"
        groups="sales_team.group_sale_manager"/>

    <!-- Shortcut under Purchase menu -->
    <menuitem
        id="menu_purchase_approval_dashboard"
        name="📊 Approval Dashboard"
        parent="purchase.menu_purchase_root"
        action="action_gifari_approval_dashboard"
        sequence="16"
        groups="purchase.group_purchase_manager"/>

</odoo>
