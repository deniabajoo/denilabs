<?xml version="1.0" encoding="utf-8"?>
<templates>

    <!-- ── Main Dashboard Template ── -->
    <t t-name="gifari_approval_dashboard.ApprovalDashboard">
        <div class="gifari-dashboard">

            <!-- Header -->
            <div class="gad-header">
                <div class="gad-header-left">
                    <h1>🏢 Approval Control Center</h1>
                    <p>Selamat datang, <strong t-esc="state.userName"/></p>
                </div>
                <div class="gad-header-right">
                    <span class="gad-date" t-esc="state.currentDate"/>
                    <button class="gad-refresh-btn" t-att-class="state.loading ? 'loading' : ''"
                            t-on-click="loadData">
                        <i class="fa fa-refresh"/>
                        <span>Refresh</span>
                    </button>
                </div>
            </div>

            <!-- Filter Bar -->
            <div class="gad-filter-bar">
                <div class="gad-filter-group">
                    <button class="gad-filter-btn"
                            t-att-class="state.moduleFilter === 'all' ? 'active' : ''"
                            t-on-click="() => this.setFilter('all')">All</button>
                    <button class="gad-filter-btn"
                            t-att-class="state.moduleFilter === 'sale' ? 'active' : ''"
                            t-on-click="() => this.setFilter('sale')">Sales</button>
                    <button class="gad-filter-btn"
                            t-att-class="state.moduleFilter === 'purchase' ? 'active' : ''"
                            t-on-click="() => this.setFilter('purchase')">Purchase</button>
                </div>
                <select class="gad-select" t-on-change="onDateRangeChange">
                    <option value="7">Last 7 Days</option>
                    <option value="14">Last 14 Days</option>
                    <option value="30">Last 30 Days</option>
                </select>
            </div>

            <!-- KPI Cards -->
            <div class="gad-kpi-grid">
                <div class="gad-kpi-card pending-so kpi-so" t-on-click="() => this.navigateTo('sale')">
                    <div class="gad-kpi-icon">📋</div>
                    <div class="gad-kpi-value" t-esc="state.kpi.so_pending || 0"/>
                    <div class="gad-kpi-label">SO Pending Approval</div>
                </div>
                <div class="gad-kpi-card pending-po kpi-po" t-on-click="() => this.navigateTo('purchase')">
                    <div class="gad-kpi-icon">🛒</div>
                    <div class="gad-kpi-value" t-esc="state.kpi.po_pending || 0"/>
                    <div class="gad-kpi-label">PO Pending Approval</div>
                </div>
                <div class="gad-kpi-card approved kpi-app">
                    <div class="gad-kpi-icon">✅</div>
                    <div class="gad-kpi-value" t-esc="state.kpi.approved_today || 0"/>
                    <div class="gad-kpi-label">Approved Today</div>
                </div>
                <div class="gad-kpi-card rejected kpi-rej">
                    <div class="gad-kpi-icon">❌</div>
                    <div class="gad-kpi-value" t-esc="state.kpi.rejected_today || 0"/>
                    <div class="gad-kpi-label">Rejected Today</div>
                </div>
                <div class="gad-kpi-card total kpi-tot">
                    <div class="gad-kpi-icon">⏳</div>
                    <div class="gad-kpi-value" t-esc="state.kpi.total_pending || 0"/>
                    <div class="gad-kpi-label">Total Pending</div>
                </div>
            </div>

            <!-- Charts + Top Discounts Grid -->
            <div class="gad-main-grid">
                <!-- Trend Chart -->
                <div class="gad-card">
                    <div class="gad-card-title">📈 Approval Trend</div>
                    <div class="gad-chart-container">
                        <canvas id="gadTrendChart"/>
                    </div>
                </div>

                <!-- Top Discount Summary -->
                <div class="gad-card">
                    <div class="gad-card-title">💰 Top Discount Requests</div>
                    <t t-if="state.pendingList.length === 0">
                        <div class="gad-empty">
                            <div class="gad-empty-icon">🎉</div>
                            <p>No pending approvals!</p>
                        </div>
                    </t>
                    <t t-else="">
                        <div style="overflow-y: auto; max-height: 240px;">
                            <t t-foreach="state.pendingList.slice(0, 5)" t-as="item" t-key="item.id + item.type">
                                <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid var(--gad-border);">
                                    <span class="gad-badge" t-att-class="item.type === 'SO' ? 'so' : 'po'" t-esc="item.type"/>
                                    <button class="gad-link-btn" t-on-click="() => this.openRecord(item)" t-esc="item.name"/>
                                    <span style="flex:1; color:var(--gad-text-muted); font-size:0.78rem;" t-esc="item.partner"/>
                                    <span class="gad-disc-cell" t-esc="item.max_discount_percent.toFixed(1) + '%'"/>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Pending Approvals Full Table -->
            <div class="gad-pending-card">
                <div class="gad-pending-header">
                    <div class="gad-card-title" style="margin:0">⏳ Pending Approvals Queue</div>
                    <span style="color:var(--gad-text-muted); font-size:0.8rem;">
                        <t t-esc="state.pendingList.length"/> orders waiting
                    </span>
                </div>

                <t t-if="state.pendingList.length === 0">
                    <div class="gad-empty">
                        <div class="gad-empty-icon">🎉</div>
                        <p>All clear! No pending approvals.</p>
                    </div>
                </t>
                <t t-else="">
                    <div class="gad-table-wrapper">
                        <table class="gad-table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Document</th>
                                    <th>Partner</th>
                                    <th>Submitted By</th>
                                    <th>Max Disc %</th>
                                    <th>Disc. Amount</th>
                                    <th>Order Total</th>
                                    <th>Submitted</th>
                                    <th>Aging</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.pendingList" t-as="item" t-key="item.type + '_' + item.id">
                                    <tr>
                                        <td>
                                            <span class="gad-badge"
                                                  t-att-class="item.type === 'SO' ? 'so' : 'po'"
                                                  t-esc="item.type"/>
                                        </td>
                                        <td>
                                            <button class="gad-link-btn"
                                                    t-on-click="() => this.openRecord(item)"
                                                    t-esc="item.name"/>
                                        </td>
                                        <td t-esc="item.partner"/>
                                        <td t-esc="item.salesperson || '—'"/>
                                        <td class="gad-disc-cell" t-esc="item.max_discount_percent.toFixed(1) + '%'"/>
                                        <td t-esc="item.currency_symbol + ' ' + Math.round(item.total_discount_amount).toLocaleString()"/>
                                        <td t-esc="item.currency_symbol + ' ' + Math.round(item.amount_total).toLocaleString()"/>
                                        <td t-esc="item.write_date"/>
                                        <td>
                                            <span class="gad-aging"
                                                  t-att-class="item.age_hours &lt; 4 ? 'green' : item.age_hours &lt; 24 ? 'amber' : 'red'">
                                                <i t-att-class="item.age_hours &lt; 4 ? 'fa fa-circle' : item.age_hours &lt; 24 ? 'fa fa-exclamation-circle' : 'fa fa-fire'"/>
                                                <t t-if="item.age_hours &lt; 1" t-esc="Math.round(item.age_hours * 60) + 'm'"/>
                                                <t t-elif="item.age_hours &lt; 24" t-esc="item.age_hours.toFixed(1) + 'h'"/>
                                                <t t-else="" t-esc="(item.age_hours / 24).toFixed(1) + 'd'"/>
                                            </span>
                                        </td>
                                        <td>
                                            <div style="display:flex; gap:6px;">
                                                <button class="gad-action-btn approve"
                                                        t-on-click="() => this.openQuickAction(item, 'approve')">
                                                    ✅ Approve
                                                </button>
                                                <button class="gad-action-btn reject"
                                                        t-on-click="() => this.openQuickAction(item, 'reject')">
                                                    ❌ Reject
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </div>

            <!-- Quick Action Modal -->
            <t t-if="state.modal.visible">
                <div class="gad-modal-overlay" t-on-click.self="closeModal">
                    <div class="gad-modal">
                        <h3 t-esc="state.modal.action === 'approve' ? '✅ Approve Order' : '❌ Reject Order'"/>
                        <p class="gad-modal-sub">
                            <t t-esc="state.modal.item.type"/> —
                            <strong t-esc="state.modal.item.name"/> |
                            <t t-esc="state.modal.item.partner"/>
                        </p>

                        <div t-if="state.modal.action === 'approve'">
                            <label>Approval Notes (Optional)</label>
                            <textarea placeholder="Add notes for this approval..."
                                      t-model="state.modal.notes"/>
                        </div>
                        <div t-else="">
                            <label>Rejection Reason <span style="color:var(--gad-rejected)">*</span></label>
                            <textarea placeholder="Please provide a clear reason for rejection..."
                                      t-model="state.modal.reason"/>
                        </div>

                        <div class="gad-modal-actions">
                            <button class="gad-modal-btn cancel" t-on-click="closeModal">Cancel</button>
                            <button class="gad-modal-btn"
                                    t-att-class="state.modal.action === 'approve' ? 'confirm-approve' : 'confirm-reject'"
                                    t-on-click="confirmQuickAction">
                                <t t-if="state.modal.action === 'approve'">✅ Confirm Approval</t>
                                <t t-else="">❌ Confirm Rejection</t>
                            </button>
                        </div>
                    </div>
                </div>
            </t>

        </div>
    </t>

</templates>
