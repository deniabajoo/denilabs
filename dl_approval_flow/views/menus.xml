<odoo>

    <!-- ================================================================
         Root menu  (appears in main app switcher)
         ================================================================ -->
    <menuitem id="menu_approval_root"
              name="Approvals"
              sequence="60"
              web_icon="dl_approval_flow,static/description/icon.png"/>

    <!-- ================================================================
         My Approvals  (first item — most used)
         ================================================================ -->
    <menuitem id="menu_my_approvals_dashboard"
              name="My Approvals"
              parent="menu_approval_root"
              action="action_my_approvals_dashboard"
              sequence="10"/>

    <menuitem id="menu_my_pending_approvals"
              name="Pending My Action"
              parent="menu_approval_root"
              action="action_my_pending_approvals"
              sequence="20"/>

    <!-- ================================================================
         All Requests
         ================================================================ -->
    <menuitem id="menu_approval_requests"
              name="All Requests"
              parent="menu_approval_root"
              action="action_approval_request"
              sequence="30"
              groups="dl_approval_flow.group_approval_manager"/>

    <!-- ================================================================
         Configuration  (Settings sub-menu)
         ================================================================ -->
    <menuitem id="menu_approval_configuration"
              name="Configuration"
              parent="menu_approval_root"
              sequence="90"
              groups="dl_approval_flow.group_approval_manager"/>

    <menuitem id="menu_approval_workflow_config"
              name="Approval Workflows"
              parent="menu_approval_configuration"
              action="action_approval_workflow_config"
              sequence="10"
              groups="dl_approval_flow.group_approval_manager"/>

</odoo>
