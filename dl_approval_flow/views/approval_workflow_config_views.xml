<odoo>

    <!-- ================================================================
         List view
         ================================================================ -->
    <record id="view_approval_workflow_config_list" model="ir.ui.view">
        <field name="name">approval.workflow.config.list</field>
        <field name="model">approval.workflow.config</field>
        <field name="arch" type="xml">
            <list string="Approval Workflow Configurations"
                  decoration-muted="not active">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_id"/>
                <field name="stage_count" string="Stages"/>
                <field name="escalation_days" string="Escalation (days)"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         Form view
         ================================================================ -->
    <record id="view_approval_workflow_config_form" model="ir.ui.view">
        <field name="name">approval.workflow.config.form</field>
        <field name="model">approval.workflow.config</field>
        <field name="arch" type="xml">
            <form string="Approval Workflow Configuration">
                <header>
                    <button name="action_generate_dynamic_integration"
                            type="object"
                            string="⚡ Generate Zero-Code Integration"
                            class="btn-success"
                            invisible="not model_id"
                            confirm="Yakin ingin membuat injeksi UI dan Security State secara otomatis untuk model ini?"/>
                    <button name="action_detect_actions"
                            type="object"
                            string="Detect Available Actions"
                            class="btn-primary"
                            invisible="not model_id"/>
                    <button name="action_view_requests"
                            type="object"
                            string="View Requests"
                            class="btn-secondary"
                            invisible="request_count == 0"/>
                </header>
                <sheet>
                    <!-- Smart button -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_requests"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list-alt"
                                invisible="request_count == 0">
                            <field name="request_count"
                                   string="Requests"
                                   widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"
                                   placeholder="e.g. Purchase Order — High Value"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Target">
                            <field name="model_id"
                                   options="{'no_create': True}"
                                   placeholder="Select an Odoo model…"/>
                            <field name="domain"
                                   widget="domain"
                                   options="{'model': 'model_name'}"
                                   placeholder="[] (matches all records)"/>
                            <field name="model_name" invisible="1"/>
                        </group>
                        <group string="Settings">
                            <field name="sequence"/>
                            <field name="escalation_days"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Approval Stages"
                              name="stages">
                            <field name="stage_ids"
                                   nolabel="1">
                                <list editable="bottom"
                                      decoration-info="approver_type == 'group'"
                                      decoration-warning="approver_type == 'field'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="approver_type"/>
                                    <field name="approver_id"
                                           optional="show"
                                           invisible="approver_type != 'user'"/>
                                    <field name="group_id"
                                           optional="show"
                                           invisible="approver_type != 'group'"/>
                                    <field name="field_name"
                                           optional="show"
                                           invisible="approver_type != 'field'"/>
                                    <field name="require_all_group_members"
                                           optional="hide"
                                           invisible="approver_type != 'group'"/>
                                    <field name="escalation_user_id"
                                           optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Gated Actions"
                              name="gated_actions">
                            <p class="text-muted" style="margin-bottom:8px;">
                                Tentukan aksi (tombol) mana yang diblokir sampai persetujuan diterima.
                                Isi <b>Method Name</b> dengan nama method Python-nya (misalnya
                                <code>action_confirm</code>, <code>action_cancel</code>).
                            </p>
                            <field name="gated_action_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="method_name"
                                           placeholder="action_confirm"/>
                                    <field name="button_label"
                                           placeholder="Confirm"/>
                                    <field name="block_on_states"
                                           optional="hide"/>
                                    <field name="error_message"
                                           optional="hide"
                                           placeholder="(opsional) Pesan error kustom…"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         Search view
         ================================================================ -->
    <record id="view_approval_workflow_config_search" model="ir.ui.view">
        <field name="name">approval.workflow.config.search</field>
        <field name="model">approval.workflow.config</field>
        <field name="arch" type="xml">
            <search string="Search Configurations">
                <field name="name"/>
                <field name="model_id"/>
                <filter string="Active" name="active"
                        domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived"
                        domain="[('active','=',False)]"/>
                <group colspan="4" col="4">
                    <filter string="Model" name="group_model"
                            context="{'group_by': 'model_id'}"/>
                    <filter string="Company" name="group_company"
                            context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         Window action
         ================================================================ -->
    <record id="action_approval_workflow_config" model="ir.actions.act_window">
        <field name="name">Approval Workflows</field>
        <field name="res_model">approval.workflow.config</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first approval workflow
            </p>
            <p>
                Define a workflow for any Odoo model and specify the stages
                each document must pass through before being approved.
            </p>
        </field>
    </record>

</odoo>
