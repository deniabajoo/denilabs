<odoo noupdate="1">

    <record id="email_template_approval_request" model="mail.template">
        <field name="name">Approval Request: Notify Approver</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="subject">Action Required: Approval Request {{ object.name }}</field>
        <field name="email_from">{{ (object.company_id.email_formatted or object.requester_id.email_formatted) }}</field>
        <field name="partner_to"/>
        <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear <t t-out="ctx.get('approver_name', 'Approver')"/>,
    </p>
    <br/>
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        An approval request requires your action:
    </p>
    <br/>
    <table style="border: 1px solid #dee2e6; border-collapse: collapse; width: 100%; font-size: 13px;">
        <tr>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold; width: 35%;">Reference</td>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6;"><t t-out="object.name"/></td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;">Document</td>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6;"><t t-out="object.res_name"/></td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;">Workflow</td>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6;"><t t-out="object.config_id.name"/></td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;">Stage</td>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6;"><t t-out="object.current_stage_id.name"/></td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;">Requested By</td>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6;"><t t-out="object.requester_id.name"/></td>
        </tr>
        <t t-if="object.deadline">
        <tr>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;">Deadline</td>
            <td style="padding: 8px 12px; border: 1px solid #dee2e6; color: #dc3545;"><t t-out="object.deadline"/></td>
        </tr>
        </t>
    </table>
    <br/>
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Please log in to Odoo and review the request at your earliest convenience.
    </p>
    <br/>
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        <a t-att-href="'/web#model=approval.request&amp;id=' + str(object.id) + '&amp;view_type=form'"
           style="background-color: #875A7B; color: #fff; padding: 8px 16px;
                  text-decoration: none; border-radius: 4px; font-size: 13px;">
            Review Request
        </a>
    </p>
    <br/>
    <p style="margin: 0px; padding: 0px; font-size: 12px; color: #6c757d;">
        This is an automated notification from your Odoo system.
    </p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
        <field name="lang">{{ object.requester_id.lang }}</field>
    </record>

</odoo>
