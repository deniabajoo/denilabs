<!--
    Template server action for automated-action integration.

    Admins can duplicate this record from Settings > Technical > Actions >
    Server Actions, then attach it to an Automated Action (ir.base.automation)
    on any model to trigger approval workflow submission automatically on
    specific events (e.g. when a sale order is confirmed).

    The server action calls ApprovalRequest.action_server_submit_approval()
    which reads active_model / active_ids from context.
-->
<odoo>
    <data noupdate="1">

        <record id="action_server_submit_for_approval" model="ir.actions.server">
            <field name="name">Approval: Submit for Approval (template)</field>
            <field name="model_id" ref="model_approval_request"/>
            <field name="binding_model_id" eval="False"/>
            <field name="state">code</field>
            <field name="code">
env['approval.request'].action_server_submit_approval()
            </field>
            <field name="group_ids" eval="[(4, ref('dl_approval_flow.group_approval_manager'))]"/>
        </record>

        <!-- Universal Dynamic Smart Button Action -->
        <record id="action_dynamic_smart_button" model="ir.actions.server">
            <field name="name">Open Approval Requests</field>
            <field name="model_id" ref="dl_approval_flow.model_approval_request"/>
            <field name="state">code</field>
            <field name="code">
action = {
    'name': 'Approval Requests',
    'type': 'ir.actions.act_window',
    'res_model': 'approval.request',
    'domain': [('res_model', '=', env.context.get('active_model')), ('res_id', '=', env.context.get('active_id'))],
    'view_mode': 'list,form',
    'context': {
        'default_res_model': env.context.get('active_model'),
        'default_res_id': env.context.get('active_id')
    },
}
            </field>
        </record>

    </data>
</odoo>
