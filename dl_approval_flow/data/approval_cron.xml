<odoo noupdate="1">

    <record id="ir_cron_escalate_approval_requests" model="ir.cron">
        <field name="name">Approval: Escalate Overdue Requests</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="state">code</field>
        <field name="code">model._cron_escalate_pending_requests()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 06:00:00')"/>
    </record>

</odoo>
