<odoo>

    <record id="view_approval_action_wizard_form" model="ir.ui.view">
        <field name="name">approval.action.wizard.form</field>
        <field name="model">approval.action.wizard</field>
        <field name="arch" type="xml">
            <form string="Approval Action">
                <group string="Request Details">
                    <field name="request_name" readonly="1"/>
                    <field name="res_name" readonly="1"/>
                    <field name="current_stage_name" readonly="1"/>
                </group>
                <group string="Action">
                    <field name="action" widget="radio"/>
                    <field name="reason"
                           placeholder="Provide a clear reason…"
                           nolabel="1"
                           colspan="2"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
