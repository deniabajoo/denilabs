<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════
         Settings — Purchase Amount Approval Configuration
         ════════════════════════════════════════════════════ -->

    <record id="res_config_settings_view_form_purchase_approval" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.purchase.approval</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='purchase_setting_container']" position="inside">

                <setting id="purchase_amount_approval_setting"
                         string="Multi-Level Amount Approval"
                         help="Require multi-level approval when Purchase Order amounts exceed configured thresholds.">
                    <field name="purchase_approval_enabled"/>
                    <div class="content-group" invisible="not purchase_approval_enabled">
                        <div class="mt8">
                            <button name="%(action_purchase_approval_level)d"
                                    icon="oi-arrow-right"
                                    type="action"
                                    string="Configure Approval Levels"
                                    class="btn-link"/>
                        </div>
                    </div>
                </setting>

            </xpath>
        </field>
    </record>

</odoo>
