<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════
         Purchase Order — Form View Extension (Approval Banner)
         ════════════════════════════════════════════════════ -->

    <record id="view_purchase_order_form_approval" model="ir.ui.view">
        <field name="name">purchase.order.form.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Approval buttons in header -->
            <xpath expr="//header" position="inside">
                <field name="approval_state" invisible="1"/>
                <field name="is_current_user_approver" invisible="1"/>
                <field name="show_approval_banner" invisible="1"/>

                <button name="action_open_approval_wizard"
                        string="Review Approval"
                        type="object"
                        class="btn-primary"
                        invisible="not is_current_user_approver"/>

                <button name="action_resubmit_approval"
                        string="Re-submit for Approval"
                        type="object"
                        class="btn-warning"
                        invisible="approval_state != 'rejected'"
                        groups="purchase.group_purchase_user"/>

                <button name="action_cancel_approval"
                        string="Cancel Approval"
                        type="object"
                        class="btn-secondary"
                        invisible="approval_state not in ('pending', 'rejected')"
                        groups="purchase.group_purchase_user"/>
            </xpath>

            <!-- Approval banner -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning text-center"
                     role="alert"
                     invisible="approval_state != 'pending'">
                    <strong>⏳ Pending Approval</strong> —
                    Level: <field name="current_approval_level_id" readonly="1" class="oe_inline"/>
                    | Pending <field name="days_pending" readonly="1" class="oe_inline"/> day(s)
                </div>
                <div class="alert alert-success text-center"
                     role="alert"
                     invisible="approval_state != 'approved'">
                    <strong>✅ Approved</strong> — Amount has been approved.
                </div>
                <div class="alert alert-danger text-center"
                     role="alert"
                     invisible="approval_state != 'rejected'">
                    <strong>❌ Rejected</strong> — Please adjust and re-submit.
                </div>
            </xpath>

            <!-- Approval History tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Amount Approval"
                      name="amount_approval_tab"
                      invisible="approval_state == 'none'">
                    <group>
                        <group>
                            <field name="approval_state" readonly="1"/>
                            <field name="submitted_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="requires_multi_approval" readonly="1"/>
                            <field name="approved_amount_untaxed" readonly="1"/>
                        </group>
                    </group>
                    <field name="approval_log_ids" readonly="1">
                        <list>
                            <field name="timestamp"/>
                            <field name="user_id"/>
                            <field name="level_id"/>
                            <field name="action"
                                   decoration-success="action == 'approve'"
                                   decoration-danger="action == 'reject'"
                                   decoration-info="action in ('submit', 'resubmit')"
                                   decoration-warning="action == 'reset'"
                                   widget="badge"/>
                            <field name="order_amount"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ════════════════════════════════════════════════════
         Purchase Order — List View Extension
         ════════════════════════════════════════════════════ -->

    <record id="view_purchase_order_list_approval" model="ir.ui.view">
        <field name="name">purchase.order.list.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="approval_state"
                       widget="badge"
                       decoration-warning="approval_state == 'pending'"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'rejected'"
                       optional="show"
                       string="Approval"/>
            </xpath>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════
         Purchase Order — Search View Extension
         ════════════════════════════════════════════════════ -->

    <record id="view_purchase_order_search_approval" model="ir.ui.view">
        <field name="name">purchase.order.search.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_purchases']" position="after">
                <separator/>
                <filter name="pending_approval"
                        string="Pending Approval"
                        domain="[('approval_state', '=', 'pending')]"/>
                <filter name="approved_amount"
                        string="Approved"
                        domain="[('approval_state', '=', 'approved')]"/>
                <filter name="rejected_amount"
                        string="Rejected"
                        domain="[('approval_state', '=', 'rejected')]"/>
            </xpath>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════
         Approval Queue — Action
         ════════════════════════════════════════════════════ -->

    <record id="action_purchase_approval_queue" model="ir.actions.act_window">
        <field name="name">Amount Approval Queue</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('approval_state', '=', 'pending')]</field>
        <field name="context">{'search_default_pending_approval': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending amount approvals
            </p>
            <p>
                Purchase Orders requiring amount approval will appear here.
            </p>
        </field>
    </record>

</odoo>
