<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════
         Sale Order — Form View Extension (Approval Banner)
         ════════════════════════════════════════════════════ -->

    <record id="view_sale_order_form_approval" model="ir.ui.view">
        <field name="name">sale.order.form.discount.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Approval Status Banner above the form -->
            <xpath expr="//header" position="inside">
                <field name="approval_state" invisible="1"/>
                <field name="is_current_user_approver" invisible="1"/>
                <field name="show_approval_banner" invisible="1"/>

                <!-- Approve/Reject button for approvers -->
                <button name="action_open_approval_wizard"
                        string="Review Approval"
                        type="object"
                        class="btn-primary"
                        invisible="not is_current_user_approver"/>

                <!-- Re-submit button for salesperson -->
                <button name="action_resubmit_approval"
                        string="Re-submit for Approval"
                        type="object"
                        class="btn-warning"
                        invisible="approval_state != 'rejected'"
                        groups="sales_team.group_sale_salesman"/>

                <!-- Cancel approval button -->
                <button name="action_cancel_approval"
                        string="Cancel Approval"
                        type="object"
                        class="btn-secondary"
                        invisible="approval_state not in ('pending', 'rejected')"
                        groups="sales_team.group_sale_salesman"/>
            </xpath>

            <!-- Approval info banner -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning text-center"
                     role="alert"
                     invisible="approval_state != 'pending'">
                    <strong>⏳ Pending Approval</strong> —
                    Level: <field name="current_approval_level_id" readonly="1" class="oe_inline"/>
                    | Max Discount: <field name="effective_max_discount" readonly="1" class="oe_inline"/>%
                    | Pending <field name="days_pending" readonly="1" class="oe_inline"/> day(s)
                </div>
                <div class="alert alert-success text-center"
                     role="alert"
                     invisible="approval_state != 'approved'">
                    <strong>✅ Approved</strong> — Discount has been approved.
                </div>
                <div class="alert alert-danger text-center"
                     role="alert"
                     invisible="approval_state != 'rejected'">
                    <strong>❌ Rejected</strong> — Please adjust the discount and re-submit.
                </div>
            </xpath>

            <!-- Stock status badge on order lines -->
            <xpath expr="//field[@name='order_line']/list/field[@name='discount']" position="after">
                <field name="stock_status"
                       widget="badge"
                       decoration-success="stock_status == 'available'"
                       decoration-warning="stock_status == 'partial'"
                       decoration-danger="stock_status == 'unavailable'"
                       optional="show"
                       string="Stock"/>
                <field name="needs_purchase" column_invisible="True"/>
            </xpath>

            <!-- Approval History tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Discount Approval"
                      name="discount_approval_tab"
                      invisible="approval_state == 'none'">
                    <group>
                        <group>
                            <field name="approval_state" readonly="1"/>
                            <field name="submitted_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="max_line_discount" readonly="1"/>
                            <field name="global_discount_percent" readonly="1"/>
                            <field name="effective_max_discount" readonly="1"/>
                        </group>
                    </group>
                    <field name="approval_log_ids" readonly="1">
                        <list>
                            <field name="timestamp"/>
                            <field name="user_id"/>
                            <field name="level_id"/>
                            <field name="action"
                                   decoration-success="action in ('approve', 'counter_offer')"
                                   decoration-danger="action == 'reject'"
                                   decoration-info="action in ('submit', 'resubmit')"
                                   widget="badge"/>
                            <field name="old_max_discount"/>
                            <field name="new_max_discount"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ════════════════════════════════════════════════════
         Sale Order — List View Extension (Approval Badge)
         ════════════════════════════════════════════════════ -->

    <record id="view_sale_order_list_approval" model="ir.ui.view">
        <field name="name">sale.order.list.discount.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="approval_state"
                       widget="badge"
                       decoration-warning="approval_state == 'pending'"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'rejected'"
                       optional="show"
                       string="Approval"/>
            </xpath>
        </field>
    </record>

    <!-- Also add to the confirmed orders list -->
    <record id="view_sale_order_list_approval_confirmed" model="ir.ui.view">
        <field name="name">sale.order.list.confirmed.discount.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="approval_state"
                       widget="badge"
                       decoration-warning="approval_state == 'pending'"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'rejected'"
                       optional="show"
                       string="Approval"/>
            </xpath>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════
         Sale Order — Search View Extension (Approval Filters)
         ════════════════════════════════════════════════════ -->

    <record id="view_sale_order_search_approval" model="ir.ui.view">
        <field name="name">sale.order.search.discount.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_quotation']" position="after">
                <separator/>
                <filter name="pending_approval"
                        string="Pending Approval"
                        domain="[('approval_state', '=', 'pending')]"/>
                <filter name="approved_discount"
                        string="Approved"
                        domain="[('approval_state', '=', 'approved')]"/>
                <filter name="rejected_discount"
                        string="Rejected"
                        domain="[('approval_state', '=', 'rejected')]"/>
            </xpath>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════
         Approval Queue — Action
         ════════════════════════════════════════════════════ -->

    <record id="action_sale_approval_queue" model="ir.actions.act_window">
        <field name="name">Discount Approval Queue</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('approval_state', '=', 'pending')]</field>
        <field name="context">{'search_default_pending_approval': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending discount approvals
            </p>
            <p>
                Sales Orders requiring discount approval will appear here.
            </p>
        </field>
    </record>

</odoo>
