<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─────────────────────────────────────────────────────────────────
         Sale Order — Form View Extension
         ───────────────────────────────────────────────────────────────── -->
    <record id="view_sale_order_form_discount_approval" model="ir.ui.view">
        <field name="name">sale.order.form.discount.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Status bar: add approval_state widget -->
            <xpath expr="//header/field[@name='state']" position="after">
                <field name="approval_state" invisible="1"/>
                <field name="needs_approval" invisible="1"/>
                <field name="is_current_user_approver" invisible="1"/>
            </xpath>

            <!-- Approval Pending Banner -->
            <xpath expr="//sheet" position="before">
                <!-- Pending banner -->
                <div class="alert alert-warning d-flex align-items-center gap-2 mb-0 rounded-0"
                     invisible="approval_state != 'pending'"
                     role="alert">
                    <i class="fa fa-clock-o fa-lg me-2"/>
                    <div class="flex-grow-1">
                        <strong>⏳ Waiting for Discount Approval</strong>
                        — This order has been submitted for approval due to excessive discount.
                        Max Discount: <strong><field name="max_discount_percent" readonly="1" nolabel="1" widget="percentage" class="d-inline"/></strong>
                        | Amount: <strong><field name="total_discount_amount" readonly="1" nolabel="1" class="d-inline"/></strong>
                    </div>
                    <div invisible="not is_current_user_approver" class="d-flex gap-2">
                        <button name="action_open_approve_wizard"
                                string="✅ Approve"
                                type="object"
                                class="btn btn-success btn-sm"
                                icon="fa-check"/>
                        <button name="action_open_reject_wizard"
                                string="❌ Reject"
                                type="object"
                                class="btn btn-danger btn-sm"
                                icon="fa-times"/>
                    </div>
                </div>

                <!-- Approved banner -->
                <div class="alert alert-success d-flex align-items-center gap-2 mb-0 rounded-0"
                     invisible="approval_state != 'approved'"
                     role="alert">
                    <i class="fa fa-check-circle fa-lg me-2"/>
                    <div class="flex-grow-1">
                        <strong>✅ Discount Approved</strong>
                        by <field name="approval_user_id" readonly="1" nolabel="1" class="d-inline fw-bold"/>
                        on <field name="approval_date" readonly="1" nolabel="1" class="d-inline"/>
                        <span invisible="not approved_max_discount_percent">
                            — Counter-offer applied: Max
                            <field name="approved_max_discount_percent" readonly="1" nolabel="1" widget="percentage" class="d-inline fw-bold"/>
                        </span>
                    </div>
                </div>

                <!-- Rejected banner -->
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-0 rounded-0"
                     invisible="approval_state != 'rejected'"
                     role="alert">
                    <i class="fa fa-times-circle fa-lg me-2"/>
                    <div class="flex-grow-1">
                        <strong>❌ Discount Rejected</strong>
                        by <field name="approval_user_id" readonly="1" nolabel="1" class="d-inline fw-bold"/>
                        — Reason: <field name="rejected_reason" readonly="1" nolabel="1" class="d-inline"/>
                    </div>
                    <button name="action_reset_approval"
                            string="🔄 Reset &amp; Revise"
                            type="object"
                            class="btn btn-outline-danger btn-sm"/>
                </div>

                <!-- Needs approval warning (draft, not yet submitted) -->
                <div class="alert alert-info d-flex align-items-center gap-2 mb-0 rounded-0"
                     invisible="not needs_approval or approval_state"
                     role="alert">
                    <i class="fa fa-exclamation-triangle fa-lg me-2"/>
                    <span>
                        <strong>ℹ️ Approval will be required</strong>
                        — This order exceeds the discount threshold and will be submitted for approval when confirmed.
                    </span>
                </div>
            </xpath>

            <!-- Approval info tab in chatter area -->
            <xpath expr="//field[@name='order_line']" position="after">
                <group string="Discount Approval Info"
                       invisible="not approval_state"
                       col="4" class="mt-2">
                    <field name="max_discount_percent" readonly="1"/>
                    <field name="total_discount_amount" readonly="1"/>
                    <field name="approval_user_id" readonly="1"/>
                    <field name="approval_date" readonly="1"/>
                    <field name="approval_notes" readonly="1" colspan="4"
                           invisible="not approval_notes"/>
                </group>
            </xpath>

        </field>
    </record>

    <!-- ─────────────────────────────────────────────────────────────────
         Sale Order — List/Tree View Extension
         ───────────────────────────────────────────────────────────────── -->
    <record id="view_sale_order_tree_discount_approval" model="ir.ui.view">
        <field name="name">sale.order.tree.discount.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="approval_state" optional="show" decoration-warning="approval_state == 'pending'"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'rejected'"/>
                <field name="max_discount_percent" optional="show" string="Max Disc %"/>
            </xpath>
        </field>
    </record>

    <!-- ─────────────────────────────────────────────────────────────────
         Sale Order — Search View Extension
         ───────────────────────────────────────────────────────────────── -->
    <record id="view_sale_order_search_discount_approval" model="ir.ui.view">
        <field name="name">sale.order.search.discount.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_sale_orders_filter']" position="after">
                <separator/>
                <filter string="⏳ Waiting Approval"
                        name="filter_pending_approval"
                        domain="[('approval_state', '=', 'pending')]"/>
                <filter string="✅ Approved"
                        name="filter_approved"
                        domain="[('approval_state', '=', 'approved')]"/>
                <filter string="❌ Rejected"
                        name="filter_rejected"
                        domain="[('approval_state', '=', 'rejected')]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="Approval State"
                        name="group_by_approval_state"
                        context="{'group_by': 'approval_state'}"/>
            </xpath>
        </field>
    </record>

    <!-- ─────────────────────────────────────────────────────────────────
         Approval Queue Action
         ───────────────────────────────────────────────────────────────── -->
    <record id="action_sale_approval_queue" model="ir.actions.act_window">
        <field name="name">Sales Approval Queue</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('approval_state', '=', 'pending')]</field>
        <field name="context">{
            'search_default_filter_pending_approval': 1,
            'default_approval_state': 'pending'
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Sales Orders pending approval! 🎉
            </p>
            <p>All discount approvals are up to date.</p>
        </field>
    </record>

</odoo>
