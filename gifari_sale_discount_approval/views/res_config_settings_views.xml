<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─────────────────────────────────────────────────────────────────
         Settings — Add Discount Approval section to Sales Settings
         ───────────────────────────────────────────────────────────────── -->
    <record id="res_config_settings_view_form_sale_discount_approval" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sale.discount.approval</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='quotation_order_setting_container']" position="inside">
                <setting id="sale_discount_approval_settings" string="Discount Approval Workflow" help="Require managerial approval when Sales Order discounts exceed a threshold.">
                    <field name="sale_disc_approval_enabled"/>
                    <div class="content-group mt-2" invisible="not sale_disc_approval_enabled">
                        <div class="row">
                            <label class="o_light_label col-3 col-form-label"
                                   for="sale_disc_approval_type"
                                   string="Trigger Approval By"/>
                            <field name="sale_disc_approval_type"
                                   class="col-4"
                                   widget="radio"
                                   options="{'horizontal': false}"/>
                        </div>
                        <div class="row mt-2"
                             invisible="sale_disc_approval_type == 'amount'">
                            <label class="o_light_label col-3 col-form-label"
                                   for="sale_disc_approval_percent"
                                   string="Max Discount %"/>
                            <field name="sale_disc_approval_percent"
                                   class="col-2"
                                   widget="percentage"/>
                        </div>
                        <div class="row mt-2"
                             invisible="sale_disc_approval_type == 'percent'">
                            <label class="o_light_label col-3 col-form-label"
                                   for="sale_disc_approval_amount"
                                   string="Max Discount Amount"/>
                            <field name="sale_disc_approval_amount" class="col-4"/>
                        </div>
                        <div class="row mt-2">
                            <label class="o_light_label col-3 col-form-label"
                                   for="sale_approval_user_ids"
                                   string="Approval Users"/>
                            <field name="sale_approval_user_ids"
                                   class="col-9"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Leave empty to fallback to Sales Manager group"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
