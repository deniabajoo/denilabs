<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <!-- Only designated approvers can approve/reject -->
    <record id="rule_sale_approval_log_company" model="ir.rule">
        <field name="name">Sale Discount Approval Log: multi-company</field>
        <field name="model_id" ref="model_sale_discount_approval_log"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_sale_approval_level_company" model="ir.rule">
        <field name="name">Sale Discount Approval Level: multi-company</field>
        <field name="model_id" ref="model_sale_discount_approval_level"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

</data>
</odoo>
