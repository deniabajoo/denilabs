<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Category for Gifari Approval modules -->
        <record id="module_category_gifari_approval" model="ir.module.category">
            <field name="name">Gifari Approvals</field>
            <field name="description">Custom approval workflows for PT Indopora</field>
            <field name="sequence">100</field>
        </record>

        <!-- Privilege for Gifari Approval modules -->
        <record id="privilege_gifari_approval" model="res.groups.privilege">
            <field name="name">Discount Approvals</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="gifari_sale_discount_approval.module_category_gifari_approval"/>
        </record>

        <!-- Sales Approval Manager group -->
        <record id="group_sale_approval_manager" model="res.groups">
            <field name="name">Sales Discount Approval Manager</field>
            <field name="privilege_id" ref="gifari_sale_discount_approval.privilege_gifari_approval"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
            <field name="comment">Users in this group can approve or reject Sales Orders that exceed the discount threshold.</field>
        </record>

    </data>
</odoo>
