<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ─────────────────────────────────────────────────────────────
             Mail Template: Approval Request (to Approvers) — C1
             ───────────────────────────────────────────────────────────── -->
        <record id="mail_template_sale_approval_request" model="mail.template">
            <field name="name">Sale Discount Approval — Request Notification</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">⚠️ Approval Needed: {{ object.name }} — {{ object.partner_id.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) | safe }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #f9f9f9; border-radius: 8px;">
                    <div style="background: linear-gradient(135deg, #f59e0b, #d97706); padding: 24px; border-radius: 8px 8px 0 0; text-align: center;">
                        <h1 style="color: #fff; margin: 0; font-size: 22px;">⚠️ Discount Approval Required</h1>
                        <p style="color: #fef3c7; margin: 8px 0 0;">PT Indopora — Sales Approval System</p>
                    </div>
                    <div style="background: #ffffff; padding: 24px; border-radius: 0 0 8px 8px; border: 1px solid #e5e7eb;">
                        <p>Dear <strong>{{ ctx.get('approver_name', 'Approver') }}</strong>,</p>
                        <p>A Sales Order requires your approval due to an excessive discount.</p>
                        <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
                            <tr style="background: #f3f4f6;">
                                <td style="padding: 10px; font-weight: bold; border: 1px solid #e5e7eb;">Order Reference</td>
                                <td style="padding: 10px; border: 1px solid #e5e7eb;">{{ object.name }}</td>
                            </tr>
                            <tr>
                                <td style="padding: 10px; font-weight: bold; border: 1px solid #e5e7eb;">Customer</td>
                                <td style="padding: 10px; border: 1px solid #e5e7eb;">{{ object.partner_id.name }}</td>
                            </tr>
                            <tr style="background: #f3f4f6;">
                                <td style="padding: 10px; font-weight: bold; border: 1px solid #e5e7eb;">Salesperson</td>
                                <td style="padding: 10px; border: 1px solid #e5e7eb;">{{ object.user_id.name or 'N/A' }}</td>
                            </tr>
                            <tr>
                                <td style="padding: 10px; font-weight: bold; border: 1px solid #e5e7eb;">Order Total</td>
                                <td style="padding: 10px; border: 1px solid #e5e7eb; color: #059669; font-weight: bold;">
                                    {{ object.currency_id.symbol }} {{ '{:,.0f}'.format(object.amount_total) }}
                                </td>
                            </tr>
                            <tr style="background: #fef2f2;">
                                <td style="padding: 10px; font-weight: bold; border: 1px solid #e5e7eb; color: #dc2626;">Max Discount %</td>
                                <td style="padding: 10px; border: 1px solid #e5e7eb; color: #dc2626; font-weight: bold;">{{ '%.1f' % object.max_discount_percent }}%</td>
                            </tr>
                            <tr style="background: #fef2f2;">
                                <td style="padding: 10px; font-weight: bold; border: 1px solid #e5e7eb; color: #dc2626;">Total Discount Amount</td>
                                <td style="padding: 10px; border: 1px solid #e5e7eb; color: #dc2626; font-weight: bold;">
                                    {{ object.currency_id.symbol }} {{ '{:,.0f}'.format(object.total_discount_amount) }}
                                </td>
                            </tr>
                        </table>
                        <div style="text-align: center; margin: 24px 0;">
                            <a href="{{ object.get_base_url() }}/odoo/sales/{{ object.id }}"
                               style="background: #f59e0b; color: white; padding: 12px 32px; border-radius: 6px; text-decoration: none; font-weight: bold;">
                                Review &amp; Approve / Reject
                            </a>
                        </div>
                        <p style="color: #6b7280; font-size: 12px;">This is an automated notification from the PT Indopora Sales Approval System.</p>
                    </div>
                </div>
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────────
             Mail Template: Approval Result (to Salesperson) — C2 + C3
             ───────────────────────────────────────────────────────────── -->
        <record id="mail_template_sale_approval_result" model="mail.template">
            <field name="name">Sale Discount Approval — Result Notification</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="email_to">{{ object.user_id.email }}</field>
            <field name="subject">{{ '✅ Approved' if ctx.get('approval_result') == 'approved' else '❌ Rejected' }}: {{ object.name }} — {{ object.partner_id.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) | safe }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
                    <div t-if="ctx.get('approval_result') == 'approved'"
                         style="background: linear-gradient(135deg, #10b981, #059669); padding: 24px; border-radius: 8px 8px 0 0; text-align: center;">
                        <h1 style="color: #fff; margin: 0; font-size: 22px;">✅ Sales Order Approved!</h1>
                    </div>
                    <div t-else=""
                         style="background: linear-gradient(135deg, #ef4444, #dc2626); padding: 24px; border-radius: 8px 8px 0 0; text-align: center;">
                        <h1 style="color: #fff; margin: 0; font-size: 22px;">❌ Sales Order Rejected</h1>
                    </div>
                    <div style="background: #ffffff; padding: 24px; border: 1px solid #e5e7eb; border-radius: 0 0 8px 8px;">
                        <p>Dear <strong>{{ object.user_id.name }}</strong>,</p>
                        <p t-if="ctx.get('approval_result') == 'approved'">
                            Your Sales Order <strong>{{ object.name }}</strong> for <strong>{{ object.partner_id.name }}</strong>
                            has been <span style="color: #059669; font-weight: bold;">APPROVED</span> by {{ ctx.get('approver_name', 'your manager') }}.
                        </p>
                        <p t-else="">
                            Your Sales Order <strong>{{ object.name }}</strong> for <strong>{{ object.partner_id.name }}</strong>
                            has been <span style="color: #dc2626; font-weight: bold;">REJECTED</span> by {{ ctx.get('approver_name', 'your manager') }}.
                        </p>
                        <p t-if="ctx.get('rejection_reason')">
                            <strong>Reason:</strong> {{ ctx.get('rejection_reason') }}
                        </p>
                        <div style="text-align: center; margin: 20px 0;">
                            <a href="{{ object.get_base_url() }}/odoo/sales/{{ object.id }}"
                               style="background: #6366f1; color: white; padding: 12px 32px; border-radius: 6px; text-decoration: none; font-weight: bold;">
                                View Sales Order
                            </a>
                        </div>
                    </div>
                </div>
            </field>
        </record>

    </data>
</odoo>
