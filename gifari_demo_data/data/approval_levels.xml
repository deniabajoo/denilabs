<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <!-- ══════════════════════════════════════════════════════
         SALE DISCOUNT APPROVAL LEVELS — 3 Level Variatif
         ══════════════════════════════════════════════════════ -->

    <!-- Enable Sale Discount Approval on main company -->
    <function model="res.company" name="write">
        <value model="res.company" search="[('id','=',1)]"/>
        <value eval="{'sale_disc_approval_enabled': True}"/>
    </function>

    <record id="sale_level_1" model="sale.discount.approval.level">
        <field name="name">Sales Supervisor (L1)</field>
        <field name="sequence">10</field>
        <field name="min_discount">10.0</field>
        <field name="max_discount">20.0</field>
        <field name="approval_mode">any_one</field>
        <field name="approver_ids" eval="[(6, 0, [ref('demo_sales_manager')])]"/>
    </record>
    <record id="sale_level_2" model="sale.discount.approval.level">
        <field name="name">Sales Manager (L2)</field>
        <field name="sequence">20</field>
        <field name="min_discount">20.0</field>
        <field name="max_discount">35.0</field>
        <field name="approval_mode">any_one</field>
        <field name="approver_ids" eval="[(6, 0, [ref('demo_sales_director')])]"/>
    </record>
    <record id="sale_level_3" model="sale.discount.approval.level">
        <field name="name">Director Board (L3)</field>
        <field name="sequence">30</field>
        <field name="min_discount">35.0</field>
        <field name="max_discount">0</field>
        <field name="approval_mode">all_must</field>
        <field name="approver_ids" eval="[(6, 0, [ref('demo_sales_manager'), ref('demo_sales_director')])]"/>
    </record>

    <!-- ══════════════════════════════════════════════════════
         PURCHASE APPROVAL LEVELS — 3 Level Variatif
         ══════════════════════════════════════════════════════ -->

    <!-- Enable Purchase Approval on main company -->
    <function model="res.company" name="write">
        <value model="res.company" search="[('id','=',1)]"/>
        <value eval="{'purchase_approval_enabled': True}"/>
    </function>

    <record id="purchase_level_1" model="purchase.approval.level">
        <field name="name">Purchasing Supervisor (L1)</field>
        <field name="sequence">10</field>
        <field name="min_amount">5000000</field>
        <field name="max_amount">50000000</field>
        <field name="approval_mode">any_one</field>
        <field name="approver_ids" eval="[(6, 0, [ref('demo_purchase_manager')])]"/>
    </record>
    <record id="purchase_level_2" model="purchase.approval.level">
        <field name="name">Purchasing Manager (L2)</field>
        <field name="sequence">20</field>
        <field name="min_amount">50000000</field>
        <field name="max_amount">200000000</field>
        <field name="approval_mode">any_one</field>
        <field name="approver_ids" eval="[(6, 0, [ref('demo_finance_director')])]"/>
    </record>
    <record id="purchase_level_3" model="purchase.approval.level">
        <field name="name">Finance Director Board (L3)</field>
        <field name="sequence">30</field>
        <field name="min_amount">200000000</field>
        <field name="max_amount">0</field>
        <field name="approval_mode">all_must</field>
        <field name="approver_ids" eval="[(6, 0, [ref('demo_purchase_manager'), ref('demo_finance_director')])]"/>
    </record>

</data>
</odoo>
